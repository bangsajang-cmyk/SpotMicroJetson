<mujoco model="mini_cheetah">

    <compiler angle="radian" autolimits="true" meshdir="../meshes/"/>

    <option iterations="1" ls_iterations="5">
        <flag eulerdamp="disable"/>
    </option>

    <default>
        <default class="mini">
            <joint damping="3" armature="0.01" frictionloss="0.1"/>

            <position kp="500" forcerange="-40 40"/>

            <default class="visual">
                <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.7 0.7 0.7 1"/>
            </default>

            <default class="collision">
                <geom type="capsule" group="3" contype="0" conaffinity="1" friction="0.8 0.02 0.01"/>
                <default class="hip_collision">
                    <geom type="capsule" size="0.03 0.03" quat="1 1 0 0"/>
                </default>
                <default class="thigh1">
                    <geom size="0.018" fromto="0 0 0 0 0 -0.11"/>
                </default>
                <default class="thigh2">
                    <geom size="0.018" fromto="0 0 -0.11 0 0 -0.21"/>
                </default>
                <default class="calf1">
                    <geom size="0.014" fromto="0 0 0 0 0 -0.11"/>
                </default>
                <default class="calf2">
                    <geom size="0.014" fromto="0 0 -0.11 0 0 -0.18"/>
                </default>
                <default class="foot">
                    <geom type="sphere" size="0.0175" pos="0 0 -0.18" condim="6" priority="1" friction="1.0 0.02 0.01" solimp="0.015 1 0.031" solref="0.002 1"/>
                </default>
            </default>

            <default class="abduction">
                <joint axis="1 0 0" damping="4" range="-0.8 0.8"/>
                <position ctrlrange="-0.8 0.8"/>
            </default>

            <default class="hip">
                <joint axis="0 -1 0" damping="4" range="-1.2 4.2"/>
                <position ctrlrange="-1.2 4.2"/>
            </default>

            <default class="knee">
                <joint axis="0 -1 0" damping="5" armature="0.01" range="-2.7 -0.8"/>
                <position ctrlrange="-2.7 -0.8"/>
            </default>
        </default>
    </default>

    <asset>
        <mesh name="mini_body" file="mini_body.stl"/>
        <mesh name="mini_abad" file="mini_abad.stl"/>
        <mesh name="mini_upper_link" file="mini_upper_link.stl"/>
        <mesh name="mini_lower_link" file="mini_lower_link.stl"/>
    </asset>

    <worldbody>
        <body name="body" pos="0 0 0.5" childclass="mini">
            <freejoint/>
            <camera name="track" pos="1.958 -2.348 0.591" xyaxes="0.768 0.641 0.000 -0.101 0.122 0.987" mode="trackcom"/>
            <inertial mass="3.3" pos="0 0 0" diaginertia="0.042 0.036 0.011"/>
            <geom class="visual" mesh="mini_body"/>
            <geom type="box" size="0.11 0.04 0.05" group="3" contype="0" conaffinity="1" friction="0.8 0.02 0.01"/>
            <site name="imu_frame" pos="0 0 0" quat="0 0 0 1"/>
            <body name="abduct_fr" pos="0.19 -0.049 0">

                <joint class="abduction" name="torso_to_abduct_fr_j"/>
                <geom class="visual" mesh="mini_abad" pos="-0.055 0 0" quat="0 0.7071 0.7071 0"/>

                <geom class="hip_collision" pos="0 -0.04 0"/>

                <body name="thigh_fr" pos="0 -0.062 0">
                    <joint class="hip" name="abduct_fr_to_thigh_fr_j"/>
                    <geom class="visual" mesh="mini_upper_link" quat="0.7071 0 -0.7071 0"/>
                    <geom class="thigh1"/>
                    <geom class="thigh2"/>
                    <body name="lower_leg_front_right" pos="0 0 -0.209">
                        <joint class="knee" name="thigh_fr_to_knee_fr_j"/>
                        <geom class="visual" mesh="mini_lower_link" quat="0 0 1 0"/>
                        <geom class="calf1"/>
                        <geom class="calf2"/>
                        <geom class="foot"/>
                        <site name="foot_front_right" pos="0 0 -0.18"/>
                    </body>
                </body>
            </body>

            <body name="abduct_fl" pos="0.19 0.049 0">
                <joint class="abduction" name="torso_to_abduct_fl_j"/>
                <geom class="visual" mesh="mini_abad" pos="-0.055 0 0" quat="0.7071 0 0 -0.7071"/>
                <geom class="hip_collision" pos="0 0.04 0"/>
                <body name="thigh_fl" pos="0 0.062 0">
                    <joint class="hip" name="abduct_fl_to_thigh_fl_j"/>
                    <geom class="visual" mesh="mini_upper_link" quat="0.7071 0 -0.7071 0"/>
                    <geom class="thigh1"/>
                    <geom class="thigh2"/>
                    <body name="lower_leg_front_left" pos="0 0 -0.209">
                        <joint class="knee" name="thigh_fl_to_knee_fl_j"/>
                        <geom class="visual" mesh="mini_lower_link" quat="0 0 1 0"/>
                        <geom class="calf1"/>
                        <geom class="calf2"/>
                        <geom class="foot"/>
                        <site name="foot_front_left" pos="0 0 -0.18"/>
                    </body>
                </body>
            </body>

            <body name="abduct_hr" pos="-0.19 -0.049 0">
                <joint class="abduction" name="torso_to_abduct_hr_j"/>
                <geom class="visual" mesh="mini_abad" pos="0.055 0 0" quat="0.7071 0 0 0.7071"/>
                <geom class="hip_collision" pos="0 -0.04 0"/>
                <body name="thigh_hr" pos="0 -0.062 0">
                    <joint class="hip" name="abduct_hr_to_thigh_hr_j"/>
                    <geom class="visual" mesh="mini_upper_link" quat="0.7071 0 -0.7071 0"/>
                    <geom class="thigh1"/>
                    <geom class="thigh2"/>
                    <body name="lower_leg_hind_right" pos="0 0 -0.209">
                        <joint class="knee" name="thigh_hr_to_knee_hr_j"/>
                        <geom class="visual" mesh="mini_lower_link" quat="0 0 1 0"/>
                        <geom class="calf1"/>
                        <geom class="calf2"/>
                        <geom class="foot"/>
                        <site name="foot_hind_right" pos="0 0 -0.18"/>
                    </body>
                </body>
            </body>

            <body name="abduct_hl" pos="-0.19 0.049 0">
                <joint class="abduction" name="torso_to_abduct_hl_j"/>
                <geom class="visual" mesh="mini_abad" pos="0.055 0 0" quat="0 0.7071 -0.7071 0"/>
                <geom class="hip_collision" pos="0 0.04 0"/>
                <body name="thigh_hl" pos="0 0.062 0">
                    <joint class="hip" name="abduct_hl_to_thigh_hl_j"/>
                    <geom class="visual" mesh="mini_upper_link" quat="0.7071 0 -0.7071 0"/>
                    <geom class="thigh1"/>
                    <geom class="thigh2"/>
                    <body name="lower_leg_hind_left" pos="0 0 -0.209">
                        <joint class="knee" name="thigh_hl_to_knee_hl_j"/>
                        <geom class="visual" mesh="mini_lower_link" quat="0 0 1 0"/>
                        <geom class="calf1"/>
                        <geom class="calf2"/>
                        <geom class="foot"/>
                        <site name="foot_hind_left" pos="0 0 -0.18"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position class="abduction" joint="torso_to_abduct_fl_j"/>
        <position class="hip"       joint="abduct_fl_to_thigh_fl_j"/>
        <position class="knee"      joint="thigh_fl_to_knee_fl_j"/>
        <position class="abduction" joint="torso_to_abduct_fr_j"/>
        <position class="hip"       joint="abduct_fr_to_thigh_fr_j"/>
        <position class="knee"      joint="thigh_fr_to_knee_fr_j"/>
        <position class="abduction" joint="torso_to_abduct_hl_j"/>
        <position class="hip"       joint="abduct_hl_to_thigh_hl_j"/>
        <position class="knee"      joint="thigh_hl_to_knee_hl_j"/>
        <position class="abduction" joint="torso_to_abduct_hr_j"/>
        <position class="hip"       joint="abduct_hr_to_thigh_hr_j"/>
        <position class="knee"      joint="thigh_hr_to_knee_hr_j"/>
    </actuator>

    
    <sensor>
        <jointpos joint="torso_to_abduct_fl_j" name="abduction_front_left_pos"/>
        <jointpos joint="abduct_fl_to_thigh_fl_j" name="hip_front_left_pos"/>
        <jointpos joint="thigh_fl_to_knee_fl_j" name="knee_front_left_pos"/>
        <jointpos joint="torso_to_abduct_hl_j" name="abduction_hind_left_pos"/>
        <jointpos joint="abduct_hl_to_thigh_hl_j" name="hip_hind_left_pos"/>
        <jointpos joint="thigh_hl_to_knee_hl_j" name="knee_hind_left_pos"/>
        <jointpos joint="torso_to_abduct_fr_j" name="abduction_front_right_pos"/>
        <jointpos joint="abduct_fr_to_thigh_fr_j" name="hip_front_right_pos"/>
        <jointpos joint="thigh_fr_to_knee_fr_j" name="knee_front_right_pos"/>
        <jointpos joint="torso_to_abduct_hr_j" name="abduction_hind_right_pos"/>
        <jointpos joint="abduct_hr_to_thigh_hr_j" name="hip_hind_right_pos"/>
        <jointpos joint="thigh_hr_to_knee_hr_j" name="knee_hind_right_pos"/>
        <jointvel joint="torso_to_abduct_fl_j" name="abduction_front_left_vel"/>
        <jointvel joint="abduct_fl_to_thigh_fl_j" name="hip_front_left_vel"/>
        <jointvel joint="thigh_fl_to_knee_fl_j" name="knee_front_left_vel"/>
        <jointvel joint="torso_to_abduct_hl_j" name="abduction_hind_left_vel"/>
        <jointvel joint="abduct_hl_to_thigh_hl_j" name="hip_hind_left_vel"/>
        <jointvel joint="thigh_hl_to_knee_hl_j" name="knee_hind_left_vel"/>
        <jointvel joint="torso_to_abduct_fr_j" name="abduction_front_right_vel"/>
        <jointvel joint="abduct_fr_to_thigh_fr_j" name="hip_front_right_vel"/>
        <jointvel joint="thigh_fr_to_knee_fr_j" name="knee_front_right_vel"/>
        <jointvel joint="torso_to_abduct_hr_j" name="abduction_hind_right_vel"/>
        <jointvel joint="abduct_hr_to_thigh_hr_j" name="hip_hind_right_vel"/>
        <jointvel joint="thigh_hr_to_knee_hr_j" name="knee_hind_right_vel"/>

        <gyro site="imu_frame" name="gyro"/>
        <velocimeter site="imu_frame" name="local_linvel"/>
        <accelerometer site="imu_frame" name="accelerometer"/>
        <framepos objtype="site" objname="imu_frame" name="global_position"/>
        <framezaxis objtype="site" objname="imu_frame" name="upvector"/>
        <framelinvel objtype="site" objname="imu_frame" name="global_linvel"/>
        <frameangvel objtype="site" objname="imu_frame" name="global_angvel"/>
        <framequat objtype="site" objname="imu_frame" name="orientation"/>
    </sensor>
</mujoco>